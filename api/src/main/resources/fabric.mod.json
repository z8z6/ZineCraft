{
	"schemaVersion": 1,
	"id": "zinecraft-api",
	"version": "${version}",
	"name": "zinecraft-api",
	"description": "Zinecraft api mod.",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/zinecraft-api/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "com.cxxcxx.zinecraft.api.ZinecraftApi",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "com.cxxcxx.zinecraft.api.client.ZinecraftApiClient",
				"adapter": "kotlin"
			}
		]
	},
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}